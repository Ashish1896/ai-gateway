GROQ_API_KEY=your_groq_api_key
REDIS_URL=redis://localhost:6379
ADMIN_API_KEY=admin_secret_key
GOOGLE_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

DEMO_MODE=true
DEMO_TENANT_API_KEY=sk_demo_public

PORT=3000
REQUEST_TIMEOUT_MS=30000
MAX_MESSAGE_CHARS=8000

CHEAP_MODEL=llama-3.3-70b-versatile
REASONING_MODEL=openai/gpt-oss-120b
FALLBACK_MODEL=gemini-2.5-flash
CLASSIFIER_MODEL=llama-3.3-70b-versatile

CHEAP_INPUT_USD_PER_1M_TOKENS=0
CHEAP_OUTPUT_USD_PER_1M_TOKENS=0
REASONING_INPUT_USD_PER_1M_TOKENS=0
REASONING_OUTPUT_USD_PER_1M_TOKENS=0

RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=60

# Score threshold for confidence escalation (0.0 - 1.0).
# Responses scoring below this trigger escalation to the reasoning model.
# Lower = fewer escalations, higher = more aggressive. Default 0.6.
CONFIDENCE_THRESHOLD=0.6

CACHE_ENABLED=true
CACHE_TTL_MS=300000
CACHE_MAX_ENTRIES=1000

# Minimum cosine similarity for a semantic cache hit (0.0 - 1.0).
# Higher = stricter matching, fewer false hits. Default 0.92.
CACHE_SEMANTIC_THRESHOLD=0.92

# -----------------------------------
# Embeddings
# -----------------------------------

# Embedding backend:
# - bge: local BGE model via Transformers.js (default)
# - google: hosted Google embeddings (text-embedding-004, gemini-embedding-001)
EMBEDDING_PROVIDER=bge

# Local BGE model used when EMBEDDING_PROVIDER=bge.
# `bge-small` is the default because it is lighter for local dev and Koyeb.
EMBEDDING_LOCAL_MODEL=Xenova/bge-small-en-v1.5

# Optional prefix for retrieval-oriented embedding models.
EMBEDDING_QUERY_PREFIX=

# Embedding prewarm is disabled by default to keep startup reliable.
EMBEDDING_PREWARM=false
EMBEDDING_PREWARM_PACE_MS=100

# Google embedding candidates used when EMBEDDING_PROVIDER=google.
EMBEDDING_MODEL_CANDIDATES=text-embedding-004,gemini-embedding-001


# -----------------------------------
# Optional Providers (disabled by default)
# -----------------------------------

# GOOGLE_API_KEY is only required for:
# - Gemini model fallback
# - Google embeddings when EMBEDDING_PROVIDER=google
