GOOGLE_API_KEY=your_google_api_key
GROQ_API_KEY=your_groq_api_key
REDIS_URL=redis://localhost:6379
ADMIN_API_KEY=admin_secret_key

DEMO_MODE=true
DEMO_TENANT_API_KEY=sk_demo_public

PORT=3000
REQUEST_TIMEOUT_MS=30000
MAX_MESSAGE_CHARS=8000

CHEAP_MODEL=llama-3.3-70b-versatile
REASONING_MODEL=openai/gpt-oss-120b
FALLBACK_MODEL=gemini-2.5-flash
CLASSIFIER_MODEL=llama-3.3-70b-versatile

CHEAP_INPUT_USD_PER_1M_TOKENS=0
CHEAP_OUTPUT_USD_PER_1M_TOKENS=0
REASONING_INPUT_USD_PER_1M_TOKENS=0
REASONING_OUTPUT_USD_PER_1M_TOKENS=0

RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=60

# Score threshold for confidence escalation (0.0 - 1.0).
# Responses scoring below this trigger escalation to the reasoning model.
# Lower = fewer escalations, higher = more aggressive. Default 0.6.
CONFIDENCE_THRESHOLD=0.6

CACHE_ENABLED=true
CACHE_TTL_MS=300000
CACHE_MAX_ENTRIES=1000

# Minimum cosine similarity for a semantic cache hit (0.0 - 1.0).
# Higher = stricter matching, fewer false hits. Default 0.92.
CACHE_SEMANTIC_THRESHOLD=0.92

EMBEDDING_MODEL_CANDIDATES=text-embedding-004,gemini-embedding-001


# -----------------------------------
# Optional Providers (disabled by default)
# -----------------------------------

# OpenAI (optional)
OPENAI_API_KEY=
ENABLE_OPENAI_PROVIDER=false

# Anthropic Claude (optional)
ANTHROPIC_API_KEY=
ENABLE_ANTHROPIC_PROVIDER=false
